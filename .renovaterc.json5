{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>home-operations/renovate-presets",
    ":semanticCommits",
  ],
  automerge: true,
  automergeType: "pr",
  platformAutomerge: true,
  ignorePaths: ["**/*.sops.*"],
  rebaseWhen: "conflicted",
  pinDigests: true,
  packageRules: [
    {
      description: "Flux OCIRepository tag is a single field — appending @sha256 makes the registry 404",
      matchFileNames: ["**/*ocirepository.yaml"],
      pinDigests: false,
    },
    {
      description: "Flux Group",
      groupName: "flux",
      matchPackageNames: ["/\\bflux/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 3,
    },
    {
      description: "Flate Group",
      groupName: "flate",
      matchPackageNames: ["/flate/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Kubernetes Group",
      groupName: "kubernetes",
      matchDepNames: ["/kubectl/", "/kubelet/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Talos Group",
      groupName: "talos",
      matchPackageNames: ["/installer/", "/talos/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Rook-Ceph Group",
      groupName: "rook-ceph",
      matchDatasources: ["docker"],
      matchPackageNames: ["/rook-ceph/", "/rook-ceph-cluster/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Envoy Group",
      groupName: "envoy",
      matchDatasources: ["docker"],
      matchPackageNames: ["/envoy/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "birdnet-go ships date-stamped nightly tags",
      matchPackageNames: ["ghcr.io/tphakala/birdnet-go"],
      versionCompatibility: "^(?<compatibility>nightly-)(?<version>\\d{8})$",
      versioning: "loose",
    },
    {
      matchManagers: ["mise"],
      semanticCommitScope: "mise",
      commitMessageTopic: "tool {{depName}}",
    },
    {
      matchUpdateTypes: ["major"],
      labels: ["type/major"],
    },
    {
      matchUpdateTypes: ["minor"],
      labels: ["type/minor"],
    },
    {
      matchUpdateTypes: ["patch"],
      labels: ["type/patch"],
    },
    {
      matchUpdateTypes: ["digest"],
      labels: ["type/digest"],
    },
    {
      matchDatasources: ["docker"],
      addLabels: ["renovate/container"],
    },
    {
      matchDatasources: ["helm"],
      addLabels: ["renovate/helm"],
    },
    {
      matchManagers: ["github-actions"],
      addLabels: ["renovate/github-action"],
    },
    {
      matchDatasources: ["github-releases"],
      addLabels: ["renovate/github-release"],
    },
  ],
}
