    {
      "id": 8,
      "type": "table",
      "title": "PVCs filling within 7 days",
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "expr": "min by(namespace, persistentvolumeclaim) (predict_linear(kubelet_volume_stats_available_bytes[6h], 7*24*3600)) <= 0",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          },
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "indexByName": {
              "namespace": 0,
              "persistentvolumeclaim": 1
            },
            "includeByName": {
              "namespace": true,
              "persistentvolumeclaim": true
            }
          }
        }
      ]
    },
